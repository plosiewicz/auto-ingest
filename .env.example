# --- Required ---

# ArangoDB cluster used for JWT auth. Same cluster the AutoGraph service
# is deployed against. PoC default below; override for other clusters.
ARANGO_URL=https://zgubculb.rnd.pilot.arango.ai
ARANGO_USER=root
ARANGO_PASSWORD=

# Public AutoGraph service URL. Find it in the AI Suite UI under
# "GenAI Services -> AutoGraph -> <your service>". It looks like:
#   https://<host>.rnd.pilot.arango.ai/autograph/<5-char-suffix>
AUTOGRAPH_API_URL=

# --- Optional ---

# Module label tagged on uploaded docs. AutoGraph uses this to scope
# corpus builds and orchestration. Pick something stable and descriptive
# for your project; default is "wtw_ingest".
AUTOGRAPH_MODULE_LABEL=wtw_ingest

# Set to "true" only if the cluster has a publicly trusted cert.
# The PoC cluster does not, so leave blank or "false".
ARANGO_TLS_VERIFY=false
