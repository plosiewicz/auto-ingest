# =============================================================================
# auto-ingest configuration
# =============================================================================
#
# Two modes of operation. Pick ONE based on whether you already have an
# AutoGraph deployment or want auto-ingest to deploy one for you.
#
# Mode A — point at an existing AutoGraph (no OpenAI key required here):
#   - fill in ARANGO_* below
#   - fill in AUTOGRAPH_API_URL
#   - leave OPENAI_API_KEY blank
#
# Mode B — auto-deploy a fresh AutoGraph for you:
#   - fill in ARANGO_* below
#   - leave AUTOGRAPH_API_URL blank
#   - fill in OPENAI_API_KEY (used by the AutoGraph service for embeddings)
#   - optionally override the DB / project / model defaults
#
# In both modes, `python ingest.py status` will tell you which mode is active.
# =============================================================================


# --- Required in BOTH modes ---

# ArangoDB cluster — same cluster the AutoGraph service is (or will be)
# deployed against. Used for JWT auth.
ARANGO_URL=https://zgubculb.rnd.pilot.arango.ai
ARANGO_USER=root
ARANGO_PASSWORD=

# Set to "true" only if the cluster has a publicly trusted cert.
ARANGO_TLS_VERIFY=false


# --- Mode A only: point at an existing AutoGraph ---

# Public AutoGraph service URL. Find it in the AI Suite UI under
# "GenAI Services -> AutoGraph -> <your service>". Looks like:
#   https://<host>.rnd.pilot.arango.ai/autograph/<5-char-suffix>
# Leave blank to fall back to a cached deployment (provisioned_service.json)
# or to auto-provision (Mode B).
AUTOGRAPH_API_URL=


# --- Mode B only: auto-deploy a fresh AutoGraph ---

# OpenAI key. Required to deploy a new AutoGraph because the service
# embeds documents and runs LLM strategy assignment using this key.
# NOT used by the ingest script directly — it's stored server-side at
# deploy time, the ingest script never sees it after that.
OPENAI_API_KEY=


# --- Optional in either mode ---

# Module label tagged on uploaded docs. AutoGraph uses this to scope
# corpus builds and orchestration. Pick something stable for your project.
AUTOGRAPH_MODULE_LABEL=auto_ingest


# --- Optional in Mode B (auto-provision tuning) ---

# DB to create + project to deploy AutoGraph against.
# Defaults: auto_ingest_db / auto_ingest
ARANGO_INGEST_DB_NAME=
ARANGO_INGEST_PROJECT_NAME=

# AutoGraph chat / embedding model selection. Defaults below mirror the
# AI Suite UI's "Add AutoGraph Service" defaults.
AUTOGRAPH_CHAT_MODEL=gpt-4.1
AUTOGRAPH_EMBEDDING_MODEL=text-embedding-3-small
AUTOGRAPH_EMBEDDING_DIM=512
